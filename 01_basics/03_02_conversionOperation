let value = 9;
let negativeValue = -value;
console.log(negativeValue); // -9 since value is 9

console.log(3/2); // 1.5
console.log(3/0); // Infinity since 3 is divided by 0
console.log(-3%2); // -1 since -3 is divided by 2 with a remainder of -1    
console.log(3**2); // 9 since 3 to the power of 2 is 9
console.log(3*3); // 9 since 3 multiplied by 3 is 9

let str1 = "Hello";
let str2 = "Yeeyansh";

console.log(str1 + " " + str2); // Hello Yeeyansh since both strings are concatenated with a space in between

console.log("1" + 3); // "13" since "1" is a string and 3 is a number
console.log(1 + "3"); // "13" since 1 is a number and "3" is a string
console.log(1 + 1 + "3"); // "23" since 1 + 1 is 2 (a number) and "3" is a string
console.log(+false) // 0 since false is converted to 0
console.log(+true) // 1 since true is converted to 1
console.log(+"") // 0 since an empty string is converted to 0
console.log(+" ") // 0 since a string with only whitespace is converted to 0
console.log(+null) // 0 since null is converted to 0
console.log(+undefined) // NaN since undefined cannot be converted to a number

let x = 2;
console.log(x++);  
console.log(++x); // 4 since x incremented by 1 after the first console